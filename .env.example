# Supabase — server-side connection (do NOT expose to the client)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>
SUPABASE_SECRET_KEY=sb_secret_<your-key>

# Cron job authentication — generate with: openssl rand -hex 32
CRON_SECRET=<64-char-hex-secret>

# Forem API key for seeding (development only)
DEV_API_KEY=<your-forem-api-key>

# CORS — comma-separated allowed origins for /api/* routes.
# The Cloud Run service URL is appended automatically by deploy.sh after the
# first deployment. Add any additional origins here as needed.
ALLOWED_ORIGINS=https://dev-signal.checkmarkdevtools.dev
